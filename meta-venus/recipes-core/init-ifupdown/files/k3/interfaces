# /etc/network/interfaces -- configuration file for ifup(8), ifdown(8)

# The loopback interface
auto lo
iface lo inet loopback

# Access point
auto ap0
iface ap0 inet static
    address 172.24.24.1
    netmask 255.255.255.0
    network 172.24.24.0

# Wired Ethernet
auto eth0
iface eth0 inet manual
