From 891efb544e0e22bb256bc800812f566e0b27a3cb Mon Sep 17 00:00:00 2001
From: Jeroen Hofstee <jhofstee@victronenergy.com>
Date: Tue, 11 Jun 2024 11:55:17 +0200
Subject: [PATCH] decline authentication when the password file doesn't exist
 yet

---
 src/flashmq-dbus-plugin.cpp | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/flashmq-dbus-plugin.cpp b/src/flashmq-dbus-plugin.cpp
index cbc0be5..0dd530b 100644
--- a/src/flashmq-dbus-plugin.cpp
+++ b/src/flashmq-dbus-plugin.cpp
@@ -88,7 +88,7 @@ AuthResult flashmq_plugin_login_check(void *thread_data, const std::string &clie
     try
     {
         if (!std::filesystem::exists(vnc_password_file_path))
-            return AuthResult::success;
+            return AuthResult::login_denied;
 
         if (std::filesystem::file_size(vnc_password_file_path) == 0)
             return AuthResult::success;
