{
  "localeFilter": {
    "filterType": "language",
    "includeChildren": false,
    "includelist": [
      "de_DE",
      "en_GB",
      "en_US",
      "es_ES",
      "fr_FR",
      "ja_JP",
      "ko_KR",
      "pt_BR",
      "ru_RU",
      "zh_CN",
      "zh_TW"
    ]
  },

  "featureFilters": {
    "collation": "exclude",
    "rbnf": "exclude",
    "translit": "exclude",
    "breakiterator": "exclude"
  },

  "converterFilter": {
    "filterType": "includelist",
    "includelist": [
      "UTF-8",
      "US-ASCII"
    ]
  }
}
