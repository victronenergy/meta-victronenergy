From d7310b9ca32cd84e342a9101beade0bd7da394f9 Mon Sep 17 00:00:00 2001
From: Chris Adams <chris.adams@qinetic.com.au>
Date: Thu, 19 Mar 2026 18:02:35 +1000
Subject: [PATCH] ScreenBlanker: detect unsuccessful screen blank/unblank

If the user has plugged in an external HDMI display then the
proprietary display's screen blank path will not exist
and attempts to write to it will fail.

Contributes to issue #2888
---
 src/screenblanker.cpp | 15 ++++++++++++---
 1 file changed, 12 insertions(+), 3 deletions(-)

diff --git a/src/screenblanker.cpp b/src/screenblanker.cpp
index 03a7ebf8d..eb740f8e1 100644
--- a/src/screenblanker.cpp
+++ b/src/screenblanker.cpp
@@ -164,9 +164,18 @@ void ScreenBlanker::setDisplayOff()
 void ScreenBlanker::setBlanked(bool blanked)
 {
 	if (supported() && blanked != m_blanked) {
-		m_blanked = blanked;
-		writeToFile(m_blankDevice, blanked ? 1 : 0);
-		emit blankedChanged();
+		if (writeToFile(m_blankDevice, blanked ? 1 : 0)) {
+			m_blanked = blanked;
+			emit blankedChanged();
+			if (blanked) {
+				qInfo() << "ScreenBlanker: screen blanked";
+			} else {
+				qInfo() << "ScreenBlanker: screen unblanked";
+			}
+		} else {
+			// this might occur if the user has connected some other HDMI display to a CerboGX.
+			qWarning() << "ScreenBlanker: unable to change screen blank status to" << blanked;
+		}
 	}
 }
 
