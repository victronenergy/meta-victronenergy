 src/nodes/victron-virtual-functions.js |  2 +-
 src/nodes/victron-virtual-switch.js    | 11 ++++++-----
 src/services/virtual-switch.js         | 22 ++++++++++++++++++++++
 4 files changed, 30 insertions(+), 7 deletions(-)

