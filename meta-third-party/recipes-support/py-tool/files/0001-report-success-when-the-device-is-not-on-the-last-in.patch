From 39f135e3da7494adc0bb3935a3413fb54db40c9a Mon Sep 17 00:00:00 2001
From: Jeroen Hofstee <jhofstee@victronenergy.com>
Date: Sat, 28 Mar 2026 12:38:10 +0100
Subject: [PATCH] report success when the device is not on the last interface

When there are multiple CAN interfaces and the device is e.g. connected
to the first one, an error PYLON_ERROR_NO_DEVICE would be returned, since
the is no device found on the last interface. Always return success when
a device is found.
---
 pylon_tool.c | 9 ++++++++-
 1 file changed, 8 insertions(+), 1 deletion(-)

diff --git a/pylon_tool.c b/pylon_tool.c
index 175c0f9..d2e67b5 100644
--- a/pylon_tool.c
+++ b/pylon_tool.c
@@ -715,7 +715,14 @@ int main(int argc, char **argv) {
                 // vic_print_message("error", "No valid devices found on any CAN interface");
                 ret = PYLON_SUCCESS;
             }
-            
+
+            // When multiple interfaces are scanned and a device is found do report that as successful.
+            // Otherwise the state of the last interface will be returned and that might be
+            // PYLON_ERROR_NO_DEVICE when the device is connected to another interface.
+
+            if (list_mode && found_device)
+                ret = PYLON_SUCCESS;
+
             free_can_interfaces(can_interfaces);
         }
     }
